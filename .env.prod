APP_NAME="Nomina API"
APP_ENV=production
APP_KEY=base64:TU_APP_KEY
APP_DEBUG=false
APP_URL=http://TU_DOMINIO_O_IP

LOG_CHANNEL=stack
LOG_LEVEL=error

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=nomina_prueba
DB_USERNAME=nomina_user
DB_PASSWORD=nomina_password

POSTGRES_DB=nomina_prueba
POSTGRES_USER=nomina_user
POSTGRES_PASSWORD=nomina_password

SESSION_DRIVER=file
CACHE_STORE=file
QUEUE_CONNECTION=sync

SANCTUM_STATEFUL_DOMAINS=TU_DOMINIO_O_IP